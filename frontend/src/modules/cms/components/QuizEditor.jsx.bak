import { useEffect, useRef, useState } from "react;
import Quill from "quill";
import { BlockMath } from "react-katex";

import "quill/dist/quill.snow.css";
import "katex/dist/katex.min.css";

function QuizEditor() {

  const editorRef = useRef(null);
  const quillRef = useRef(null);

  const [latex, setLatex] = useState("");
  const [options, setOptions] = useState(["", ""]);

  useEffect(() => {

    if (editorRef.current) {

      quillRef.current = new Quill(editorRef.current, {
        theme: "snow",
        placeholder: "Type quiz question here...",
        modules: {
          toolbar: [
            ["bold", "italic", "underline"],
            [{ list: "ordered" }, { list: "bullet" }],
            ["link"]
          ]
        }
      });

    }

  }, []);

  // Insert math syntax into editor
  const insertMath = (latexSymbol) => {

    const quill = quillRef.current;

    const range = quill.getSelection(true);

    quill.insertText(range.index, ` $${latexSymbol}$ `);

  };

  // Option handlers
  const addOption = () => {
    setOptions([...options, ""]);
  };

  const removeOption = (index) => {
    const newOptions = options.filter((_, i) => i !== index);
    setOptions(newOptions);
  };

  const handleOptionChange = (index, value) => {

    const newOptions = [...options];

    newOptions[index] = value;

    setOptions(newOptions);

  };

  const handleSubmit = () => {

    const questionHTML = quillRef.current.root.innerHTML;

    const quizData = {
      question: questionHTML,
      equationPreview: latex,
      options: options
    };

    console.log("Quiz Data:", quizData);

  };

  return (

    <div style={{ maxWidth: "800px", margin: "auto", padding: "30px" }}>

      <h2>Create Quiz Question</h2>

      {/* Math toolbar */}

      <h3>Math Symbols</h3>

      <div style={{ marginBottom: "15px" }}>

        <button onClick={() => insertMath("\\sum_{i=1}^{n}")}>Σ</button>

        <button onClick={() => insertMath("\\int_a^b")}>∫</button>

        <button onClick={() => insertMath("\\pi")}>π</button>

        <button onClick={() => insertMath("\\sqrt{}")}>√</button>

      </div>

      {/* Question Editor */}

      <h3>Question</h3>

      <div
        ref={editorRef}
        style={{ height: "200px", marginBottom: "20px" }}
      />

      {/* Equation preview */}

      <h3>Equation Preview</h3>

      <input
        type="text"
        placeholder="\int_0^1 x^2 dx"
        value={latex}
        onChange={(e) => setLatex(e.target.value)}
        style={{ width: "100%", padding: "8px" }}
      />

      <div style={{ marginTop: "10px" }}>

        {latex && <BlockMath math={latex} />}

      </div>

      {/* Options */}

      <h3>Answer Options</h3>

      {options.map((opt, index) => (

        <div key={index} style={{ display: "flex", marginBottom: "10px" }}>

          <input
            type="text"
            placeholder={`Option ${index + 1}`}
            value={opt}
            onChange={(e) => handleOptionChange(index, e.target.value)}
            style={{ flex: 1, padding: "8px" }}
          />

          <button
            onClick={() => removeOption(index)}
            style={{ marginLeft: "10px" }}
          >
            Remove
          </button>

        </div>

      ))}

      <button onClick={addOption}>Add Option</button>

      {/* Submit */}

      <div style={{ marginTop: "30px" }}>

        <button
          onClick={handleSubmit}
          style={{ padding: "10px 20px", fontSize: "16px" }}
        >
          Save Quiz
        </button>

      </div>

    </div>

  );

}

export default QuizEditor;
