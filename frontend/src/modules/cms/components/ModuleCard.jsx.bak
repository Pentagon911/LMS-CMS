const ModuleCard = ({ code, title, color }) => {
  const cardStyle = {
    background: `linear-gradient(145deg, rgba(0,0,0,0.8) 0%, ${
      color || "#6c5ce7"
    } 50%, white 100%)`,
    borderRadius: "14px",
    padding: "20px 16px 16px 16px",
    width: "200px",
    height: "120px",
    boxShadow: "8px 8px 15px rgba(0,0,0,0.3)",
    position: "relative",
    overflow: "hidden",
    fontFamily: "Arial, sans-serif",
    cursor: "pointer",
    transition: "all 0.25s ease",
    color: "#fff",
  };

  // Folder tab (top small rectangle)
  const tabStyle = {
    position: "absolute",
    top: "5px",
    left: "5px",
    width: "190px",
    height: "10px",
    background: color || "#6c5ce7",
    borderTopLeftRadius: "8px",
    borderTopRightRadius: "8px",
    boxShadow: "0 4px 8px rgba(0,0,0,0.2)",
  };

  const codeStyle = {
    fontWeight: "700",
    fontSize: "18px",
    letterSpacing: "1px",
    style: "bold",
  };

  const titleStyle = {
    fontSize: "13px",
    marginTop: "6px",
    fontWeight: "700",
  };

  return (
    <div
      style={cardStyle}
      onMouseEnter={(e) => {
        e.currentTarget.style.transform = "translateY(-6px) scale(1.05)";
        e.currentTarget.style.boxShadow =
          "15px 15px 25px rgba(0,0,0,0.5)";
      }}
      onMouseLeave={(e) => {
        e.currentTarget.style.transform = "scale(1)";
        e.currentTarget.style.boxShadow =
          "8px 8px 15px rgba(0,0,0,0.3)";
      }}
    >
      <div style={tabStyle}></div>

      <div style={{ position: "relative", zIndex: 2 }}>
        <div style={codeStyle}>{code}</div>
        <div style={titleStyle}>{title}</div>
      </div>

    </div>
  );
};

export default ModuleCard;
